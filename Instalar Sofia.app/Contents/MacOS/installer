#!/bin/bash
# ═══════════════════════════════════════════
# Sofia 2.0 — Instalador Visual para Mac
#
# Este script roda dentro de um .app bundle.
# Nenhuma janela de Terminal aparece.
# Toda a interface usa dialogos nativos do macOS.
# ═══════════════════════════════════════════

PLUGIN_NAME="sofia"
LOG_FILE="/tmp/sofia-install.log"

# Garantir PATH completo (dentro de .app o PATH e minimo)
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin:$PATH"

# Limpar log
echo "Sofia 2.0 — Instalacao iniciada em $(date)" > "$LOG_FILE"

# ─────────────────────────────────────
# Funcoes de UI (dialogos nativos macOS)
# ─────────────────────────────────────

show_dialog() {
    osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\" with title \"Sofia 2.0\" with icon note" 2>/dev/null
}

show_error() {
    osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\" with title \"Sofia 2.0 — Erro\" with icon stop" 2>/dev/null
}

show_confirm() {
    osascript -e "button returned of (display dialog \"$1\" buttons {\"Cancelar\", \"$2\"} default button \"$2\" with title \"Sofia 2.0\" with icon note)" 2>/dev/null
}

show_progress() {
    osascript -e "display notification \"$1\" with title \"Sofia 2.0\" subtitle \"$2\"" 2>/dev/null
}

run_with_admin() {
    osascript -e "do shell script \"$1\" with administrator privileges" 2>>"$LOG_FILE"
}

has_cmd() {
    command -v "$1" >/dev/null 2>&1
}

# ─────────────────────────────────────
# Tela de boas-vindas
# ─────────────────────────────────────

REPLY=$(osascript 2>/dev/null <<'WELCOME'
button returned of (display dialog "Bem-vindo ao instalador da Sofia 2.0!

Vou preparar seu computador com tudo que precisa:

  ✦  Node.js (necessario para rodar o Claude)
  ✦  Claude Code (a inteligencia artificial)
  ✦  yt-dlp (coleta dados de videos — gratis)
  ✦  Plugin Sofia (instalado automaticamente)

Leva uns 5 minutos. Voce nao precisa fazer nada." buttons {"Cancelar", "Instalar"} default button "Instalar" with title "Sofia 2.0 — Instalador" with icon note)
WELCOME
)

if [ "$REPLY" != "Instalar" ]; then
    exit 0
fi

# ─────────────────────────────────────
# Variavel para rastrear erros
# ─────────────────────────────────────
ERRORS=""

# ─────────────────────────────────────
# 1. Xcode Command Line Tools (pre-requisito)
# ─────────────────────────────────────
show_progress "Passo 1 de 5" "Verificando ferramentas do sistema..."

if ! xcode-select -p >/dev/null 2>&1; then
    show_progress "Passo 1 de 5" "Instalando ferramentas do sistema..."
    # xcode-select --install mostra um dialog nativo do macOS
    xcode-select --install 2>>"$LOG_FILE"

    # Esperar a instalacao terminar (xcode-select --install e assincrono)
    echo "Aguardando Xcode CLT..." >> "$LOG_FILE"
    until xcode-select -p >/dev/null 2>&1; do
        sleep 5
    done
fi

echo "Xcode CLT: OK" >> "$LOG_FILE"

# ─────────────────────────────────────
# 2. Homebrew
# ─────────────────────────────────────
show_progress "Passo 2 de 5" "Verificando Homebrew..."

if ! has_cmd brew; then
    show_progress "Passo 2 de 5" "Instalando Homebrew (pode demorar 2 min)..."

    # Criar diretorio com permissoes de admin se necessario
    if [ "$(uname -m)" = "arm64" ] && [ ! -d /opt/homebrew ]; then
        run_with_admin "mkdir -p /opt/homebrew && chown -R $(whoami):admin /opt/homebrew" 2>>"$LOG_FILE"
    fi

    # Instalar Homebrew sem interacao
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" </dev/null >>"$LOG_FILE" 2>&1

    # Atualizar PATH
    if [ -f /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -f /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi

    if ! has_cmd brew; then
        ERRORS="$ERRORS\n• Homebrew não pôde ser instalado"
        echo "ERRO: Homebrew falhou" >> "$LOG_FILE"
    fi
fi

echo "Homebrew: $(command -v brew 2>/dev/null || echo 'FALHOU')" >> "$LOG_FILE"

# ─────────────────────────────────────
# 3. Node.js
# ─────────────────────────────────────
show_progress "Passo 3 de 5" "Verificando Node.js..."

if ! has_cmd node; then
    show_progress "Passo 3 de 5" "Instalando Node.js..."

    if has_cmd brew; then
        brew install node >>"$LOG_FILE" 2>&1
    else
        # Fallback: baixar .pkg oficial
        NODE_VERSION="22.15.0"
        ARCH="$(uname -m)"
        if [ "$ARCH" = "arm64" ]; then
            NODE_PKG="node-v${NODE_VERSION}-darwin-arm64"
        else
            NODE_PKG="node-v${NODE_VERSION}-darwin-x64"
        fi
        curl -sL "https://nodejs.org/dist/v${NODE_VERSION}/${NODE_PKG}.pkg" -o /tmp/node.pkg 2>>"$LOG_FILE"
        if [ -f /tmp/node.pkg ]; then
            run_with_admin "installer -pkg /tmp/node.pkg -target /" 2>>"$LOG_FILE"
            rm -f /tmp/node.pkg
        fi
    fi

    # Atualizar PATH
    export PATH="/usr/local/bin:$PATH"

    if ! has_cmd node; then
        ERRORS="$ERRORS\n• Node.js não pôde ser instalado"
        echo "ERRO: Node.js falhou" >> "$LOG_FILE"
    fi
fi

echo "Node.js: $(node --version 2>/dev/null || echo 'FALHOU')" >> "$LOG_FILE"

# ─────────────────────────────────────
# 4. Claude Code + yt-dlp
# ─────────────────────────────────────
show_progress "Passo 4 de 5" "Instalando Claude Code e yt-dlp..."

# Claude Code
if ! has_cmd claude; then
    if curl -fsSL https://claude.ai/install.sh 2>/dev/null | bash >>"$LOG_FILE" 2>&1; then
        echo "Claude Code: instalador nativo OK" >> "$LOG_FILE"
    elif has_cmd npm; then
        npm install -g @anthropic-ai/claude-code >>"$LOG_FILE" 2>&1
        echo "Claude Code: npm OK" >> "$LOG_FILE"
    else
        ERRORS="$ERRORS\n• Claude Code não pôde ser instalado"
        echo "ERRO: Claude Code falhou" >> "$LOG_FILE"
    fi
    # Atualizar PATH para incluir onde Claude Code pode ter sido instalado
    export PATH="$HOME/.claude/local/bin:$HOME/.local/bin:$PATH"
fi

# yt-dlp
if ! has_cmd yt-dlp; then
    if has_cmd brew; then
        brew install yt-dlp >>"$LOG_FILE" 2>&1
    elif has_cmd pip3; then
        pip3 install yt-dlp >>"$LOG_FILE" 2>&1
    else
        # Download direto do binario
        curl -sL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_macos -o /usr/local/bin/yt-dlp 2>>"$LOG_FILE"
        chmod +x /usr/local/bin/yt-dlp 2>/dev/null
    fi

    if ! has_cmd yt-dlp; then
        ERRORS="$ERRORS\n• yt-dlp não pôde ser instalado"
        echo "ERRO: yt-dlp falhou" >> "$LOG_FILE"
    fi
fi

echo "Claude: $(command -v claude 2>/dev/null || echo 'FALHOU')" >> "$LOG_FILE"
echo "yt-dlp: $(command -v yt-dlp 2>/dev/null || echo 'FALHOU')" >> "$LOG_FILE"

# ─────────────────────────────────────
# 5. Instalar plugin Sofia via marketplace
# ─────────────────────────────────────
show_progress "Passo 5 de 5" "Instalando plugin Sofia..."

REPO_URL="https://github.com/srbentostk/smart-content-plugin"

if has_cmd claude; then
    if claude plugin install "$PLUGIN_NAME" >>"$LOG_FILE" 2>&1; then
        echo "Plugin Sofia: instalado via marketplace" >> "$LOG_FILE"
    else
        echo "Plugin Sofia: marketplace falhou, tentando via GitHub..." >> "$LOG_FILE"
        if claude plugin marketplace add "$REPO_URL" >>"$LOG_FILE" 2>&1 && \
           claude plugin install "$PLUGIN_NAME" >>"$LOG_FILE" 2>&1; then
            echo "Plugin Sofia: instalado via GitHub" >> "$LOG_FILE"
        else
            ERRORS="$ERRORS\n• Plugin Sofia nao pode ser instalado automaticamente.\n  Abra o Claude e digite: /plugin install sofia"
            echo "ERRO: Plugin install falhou" >> "$LOG_FILE"
        fi
    fi
else
    ERRORS="$ERRORS\n• Claude Code nao esta disponivel para instalar o plugin"
    echo "ERRO: Claude nao encontrado para instalar plugin" >> "$LOG_FILE"
fi

# ─────────────────────────────────────
# Resultado final
# ─────────────────────────────────────

if [ -z "$ERRORS" ]; then
    osascript 2>/dev/null <<'SUCCESS'
display dialog "Instalacao completa!

Para usar a Sofia:

1. Abra o Terminal
   (Command + Espaco → digite Terminal)

2. Digite: claude

3. Na primeira vez, faca login em claude.ai

4. Depois digite:
   /sofia:setup

Pronto! A Sofia vai te guiar a partir dai." buttons {"OK"} default button "OK" with title "Sofia 2.0 — Sucesso" with icon note
SUCCESS
else
    osascript -e "display dialog \"Instalacao parcial.\n\nAlguns itens nao puderam ser instalados:$ERRORS\n\nConsulte o log em:\n/tmp/sofia-install.log\n\nOu peca ajuda ao seu instrutor.\" buttons {\"OK\"} default button \"OK\" with title \"Sofia 2.0 — Atencao\" with icon caution" 2>/dev/null
fi

echo "Instalacao finalizada em $(date)" >> "$LOG_FILE"
